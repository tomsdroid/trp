# ==========================================
# 1. DEPENDENCIES (Node.js)
# ==========================================
node_modules/
package-lock.json # (Opsional: Hapus baris ini jika kamu ingin mengunci versi package di Git)

# ==========================================
# 2. HASIL BUILD VUE / VITE
# ==========================================
dist/
dist-ssr/
*.local

# ==========================================
# 3. ENVIRONMENT VARIABLES (SANGAT PENTING!)
# ==========================================
# Jangan biarkan file .env berisi token Telegram/API bocor ke GitHub
.env
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 4. CORDOVA
# ==========================================
cordova/platforms/
cordova/plugins/
# Folder www diabaikan karena isinya di-generate otomatis oleh Vite (npm run build)
cordova/www/
# File Keystore & APK JANGAN SAMPAI ter-upload ke Git publik
cordova/*.jks
cordova/*.keystore
cordova/*.apk
cordova/*.aab

# ==========================================
# 5. LOG ERROR & DEBUGGING
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ==========================================
# 6. FILE SISTEM & EDITOR (VS Code, Mac, Windows)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
