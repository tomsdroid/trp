{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/landing/:path*"
    }
  ]
}
